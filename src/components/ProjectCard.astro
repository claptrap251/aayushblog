---
interface Props {
  title: string;
  description: string;
  url: string;
  tags: string[];
}

const { title, description, url, tags } = Astro.props;
---

<a href={url} target="_blank" rel="noopener" class="project-card">
  <div class="card-header">
    <span class="folder">&#128193;</span>
    <span class="arrow">↗</span>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <div class="tags">
    {tags.map((t) => <span class="tag">{t}</span>)}
  </div>
</a>

<style>
  .project-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .project-card:hover {
    border-color: var(--muted);
    text-decoration: none;
  }
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: start;
    margin-bottom: 0.75rem;
  }
  .folder {
    font-size: 1.2rem;
    color: var(--muted);
  }
  .arrow {
    font-size: 0.8rem;
    color: var(--accent);
  }
  h3 {
    margin-bottom: 0.5rem;
  }
  p {
    font-size: 0.8rem;
    color: var(--body);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
</style>
