---
import SocialLinks from "./SocialLinks.astro";
---

<footer>
  <div class="footer-inner">
    <SocialLinks />
    <p class="copyright">&copy; {new Date().getFullYear()} /home/ash</p>
  </div>
</footer>

<style>
  footer {
    margin-top: auto;
    border-top: 1px solid var(--border);
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
  }
  .copyright {
    color: var(--muted);
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
